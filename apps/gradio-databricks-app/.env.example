# Copy to .env and fill in values for local development.
# These are NOT used in Databricks Apps — use app.yaml valueFrom instead.

APP_NAME=Gradio Databricks Starter
APP_PORT=8000
APP_HOST=0.0.0.0
APP_DEBUG=true
LOG_LEVEL=DEBUG

# Databricks resources (leave empty to run with mock data)
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=
SERVING_ENDPOINT_NAME=

# Databricks auth for local SDK usage (uses ~/.databrickscfg profile by default)
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...
